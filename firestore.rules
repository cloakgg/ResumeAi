rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // User: { uid, displayName, email, photoURL, linkedin, instagram, facebook, phoneNumber, stripeLink, category, createdAt }
    // Resume: { id, userId, content, category, published, stars, reviewCount, createdAt }
    // Review: { id, resumeId, reviewerId, reviewerName, rating, comment, createdAt }
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('linkedin' in data) || data.linkedin is string) &&
             (!('instagram' in data) || data.instagram is string) &&
             (!('facebook' in data) || data.facebook is string) &&
             (!('phoneNumber' in data) || data.phoneNumber is string) &&
             (!('stripeLink' in data) || data.stripeLink is string);
    }
    
    function isValidResume(data) {
      return data.keys().hasAll(['userId', 'content']) &&
             data.userId is string &&
             data.content is string &&
             data.content.size() < 10000;
    }
    
    function isValidReview(data) {
      return data.keys().hasAll(['resumeId', 'reviewerId', 'rating']) &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() < 1000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }
    
    match /resumes/{resumeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidResume(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && isValidResume(request.resource.data)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stars', 'reviewCount']))
      );
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.reviewerId == request.auth.uid && isValidReview(request.resource.data);
      allow update, delete: if isAuthenticated() && resource.data.reviewerId == request.auth.uid;
    }
  }
}
